---
// src/pages/vakansii.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import ContactForm from "../components/home/ContactForm.astro";
import VacancyAccordion from "../components/vacancies/VacancyAccordion.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import avitoIcon from "../assets/avito.svg";

const [contactsEntry] = (await getCollection("site")).sort((a, b) =>
    a.id.localeCompare(b.id),
);

if (!contactsEntry) {
    throw new Error("Site contacts content is missing in src/content/site.");
}

const contacts = contactsEntry.data;
---

<BaseLayout 
    title="Вакансии ООО «Рубеж» — Работа в дорожном строительстве Архангельск"
    description="Присоединяйтесь к команде ООО «Рубеж». Актуальные вакансии в дорожном строительстве: водители самосвалов, машинисты экскаваторов и бульдозеров в Архангельске."
>
    <Header />
    
    <main>
        <PageHeader 
            title="Вакансии" 
            subtitle="Карьера" 
            highlight=""
        >
            <p class="text-white/70 text-lg mt-8 leading-relaxed max-w-2xl">
                ООО «Рубеж» — это стабильность, масштабные проекты и современный автопарк. Ищете надежную работу со стабильными выплатами? Приглашаем ответственных профессионалов в нашу команду.
            </p>
        </PageHeader>

        <!-- Список вакансий -->
        <section class="py-24 bg-zinc-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row items-center justify-between gap-8 mb-16">
                    <div>
                        <h2 class="font-heading text-4xl uppercase text-zinc-900 leading-none">
                            Открытые позиции
                        </h2>
                        <p class="text-zinc-500 mt-2">Выберите подходящую вакансию и отправьте отклик</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-sm font-bold text-zinc-400 uppercase tracking-widest">Больше вакансий:</span>
                        <div class="flex gap-2">
                            <a href={contacts.hhUrl} target="_blank" class="w-10 h-10 rounded-lg bg-white border border-zinc-200 flex items-center justify-center text-zinc-400 hover:text-red-600 hover:border-red-600 transition-all shadow-sm" aria-label="hh.ru">
                                <span class="font-bold text-xs">hh</span>
                            </a>
                            <a href={contacts.avitoUrl} target="_blank" class="w-10 h-10 rounded-lg bg-white border border-zinc-200 flex items-center justify-center text-zinc-400 hover:text-brand-dark hover:border-brand-dark transition-all shadow-sm" aria-label="Avito">
                                <Image src={avitoIcon} alt="Avito" width={16} height={16} loading="lazy" />
                            </a>
                        </div>
                    </div>
                </div>

                <VacancyAccordion />

                <!-- Если не нашли вакансию -->
                <div class="mt-20 p-8 sm:p-12 bg-white rounded-3xl border border-zinc-200 shadow-sm relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-8 opacity-5">
                        <Icon name="lucide:mail" class="w-32 h-32" />
                    </div>
                    <div class="relative z-10 max-w-2xl">
                        <h3 class="font-heading text-3xl uppercase text-zinc-900 mb-4">Не нашли подходящую вакансию?</h3>
                        <p class="text-zinc-500 text-lg leading-relaxed mb-8">
                            Мы всегда находимся в поиске талантливых кадров! Отправьте свое резюме на нашу почту, и мы обязательно свяжемся с вами при появлении новых открытых позиций.
                        </p>
                        <div class="flex flex-wrap gap-6">
                            <a href={`mailto:${contacts.hrEmail}`} class="flex items-center gap-3 group">
                                <div class="w-12 h-12 rounded-xl bg-brand-dark flex items-center justify-center text-white shadow-lg shadow-brand-dark/20 group-hover:bg-brand-light transition-colors">
                                    <Icon name="lucide:mail" class="w-6 h-6" />
                                </div>
                                <div>
                                    <p class="text-xs text-zinc-400 font-bold uppercase tracking-widest">Email для резюме</p>
                                    <p class="text-zinc-900 font-bold">{contacts.hrEmail}</p>
                                </div>
                            </a>
                            <a href={`tel:${contacts.hrPhoneHref}`} class="flex items-center gap-3 group">
                                <div class="w-12 h-12 rounded-xl bg-zinc-900 flex items-center justify-center text-white shadow-lg shadow-zinc-900/20 group-hover:bg-zinc-700 transition-colors">
                                    <Icon name="lucide:phone" class="w-6 h-6" />
                                </div>
                                <div>
                                    <p class="text-xs text-zinc-400 font-bold uppercase tracking-widest">Отдел кадров</p>
                                    <p class="text-zinc-900 font-bold">{contacts.hrPhoneDisplay}</p>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <ContactForm />
    </main>

    <Footer />
</BaseLayout>
