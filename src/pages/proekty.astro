---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import ContactForm from "../components/home/ContactForm.astro";
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const title = "Проекты (Архангельск) — ООО «Рубеж»";
const description = "Фотогалерея проектов компании ООО «Рубеж»: дорожные, земляные и инженерные работы в Архангельске и области.";

// Получаем ВСЕ проекты (без ограничения в 4 шт) и сортируем по order
const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={title} description={description}>
    <Header />
    
    <PageHeader
        title="Наши проекты"
        highlight=""
        subtitle=""
    >
        <!-- <p class="text-slate-400 text-lg md:text-xl leading-relaxed mb-4">
            В этом разделе представлены реализованные проекты. Откройте
            карточку, чтобы посмотреть полную фотогалерею объекта.
        </p> -->
    </PageHeader>

    <section class="py-16 bg-zinc-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-white rounded border border-zinc-200 shadow-sm p-5 sm:p-6 lg:p-8">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {projects.map((project) => (
                <article class="project-gallery">
                  <!-- Главная обложка -->
                  <a
                    href={project.data.images[0].src}
                    data-pswp-width={project.data.images[0].width}
                    data-pswp-height={project.data.images[0].height}
                    data-pswp-caption={`<div class=\"pswp-caption-inner\"><h4>${project.data.title}</h4><p>${project.data.description}</p></div>`}
                    target="_blank"
                    class="project-item group relative overflow-hidden rounded aspect-[4/3] cursor-zoom-in text-left block"
                    aria-label={`Открыть проект: ${project.data.title}`}
                  >
                    <!-- Фото -->
                    <Image
                      src={project.data.images[0]}
                      alt={project.data.title}
                      widths={[400, 700]}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                      loading="lazy"
                      quality={85}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />

                    <div class="absolute inset-0 bg-black/35 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
                    <div class="absolute right-3 top-3 rounded bg-white/90 px-2.5 py-1 text-xs font-semibold text-zinc-900
                                opacity-0 transition-all duration-300 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0
                                flex items-center gap-1.5">
                      <Icon name="lucide:images" class="w-3.5 h-3.5" />
                      {project.data.images.length} фото
                    </div>
                    <div class="absolute left-3 bottom-3 rounded bg-black/70 px-2.5 py-1 text-[11px] font-medium text-white
                                opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                      Открыть галерею
                    </div>
                  </a>

                  <div class="mt-2">
                    <h3 class="text-center text-zinc-900 uppercase text-xl leading-tight">
                      {project.data.title}
                    </h3>
                  </div>

                  <!-- Скрытые фотографии проекта для галереи -->
                  {project.data.images.slice(1).map((img) => (
                    <a
                      href={img.src}
                      data-pswp-width={img.width}
                      data-pswp-height={img.height}
                      data-pswp-caption={`<div class=\"pswp-caption-inner\"><h4>${project.data.title}</h4><p>${project.data.description}</p></div>`}
                      target="_blank"
                      class="hidden"
                    >
                      <Image 
                        src={img} 
                        alt={`${project.data.title} фото`} 
                        width={img.width > 1200 ? 1200 : img.width}
                        loading="lazy" 
                        quality={80} 
                      />
                    </a>
                  ))}
                </article>
              ))}
              </div>
            </div>
        </div>
    </section>

    <!-- Форма в конце -->
    <ContactForm />

    <Footer />
</BaseLayout>

<style>
  /* Кастомизация PhotoSwipe под стилистику сайта */
  :global(.pswp__bg) {
    background: rgba(0, 0, 0, 0.9) !important;
    backdrop-filter: blur(8px);
  }
  :global(.pswp__top-bar) {
    background: transparent !important;
  }
  :global(.pswp__counter) {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 14px;
    letter-spacing: 0.05em;
  }
  :global(.pswp__custom-caption) {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 14px 20px 18px;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.78), rgba(0, 0, 0, 0));
    pointer-events: none;
  }
  :global(.pswp-caption-inner h4) {
    font-family: var(--font-heading, Impact, sans-serif);
    font-size: 18px;
    line-height: 1.1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  :global(.pswp-caption-inner p) {
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.9);
    max-width: 820px;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.project-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 0.9,
    padding: { top: 20, bottom: 20, left: 20, right: 20 },
    wheelToZoom: true,
    showHideAnimationType: 'zoom',
  });

  lightbox.on('uiRegister', () => {
    const ui = lightbox.pswp?.ui;
    if (!ui) return;

    ui.registerElement({
      name: 'custom-caption',
      order: 9,
      isButton: false,
      appendTo: 'root',
      html: '',
      onInit: (el, pswp) => {
        const updateCaption = () => {
          const currSlideElement = pswp.currSlide?.data?.element;
          const captionHTML =
            currSlideElement instanceof HTMLElement
              ? currSlideElement.getAttribute('data-pswp-caption') || ''
              : '';
          el.innerHTML = captionHTML;
        };

        pswp.on('change', updateCaption);
        updateCaption();
      },
    });
  });

  lightbox.init();
</script>
