---
// src/pages/arenda-spetstehniki.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import EquipmentCard from "../components/equipment/EquipmentCard.astro";
import LeadForm from "../components/ui/LeadForm.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const equipmentCollection = await getCollection('equipment');
const [contactsEntry] = (await getCollection('site')).sort((a, b) =>
    a.id.localeCompare(b.id),
);

if (!contactsEntry) {
    throw new Error('Site contacts content is missing in src/content/site.');
}

const contacts = contactsEntry.data;

const equipment = equipmentCollection
    .flatMap((entry) => entry.data.items)
    .sort((a, b) => a.order - b.order);

const categories = [
    'Все',
    ...Array.from(new Set(equipment.map((item) => item.category))),
];
---

<BaseLayout
    title="Аренда спецтехники в Архангельске — ООО «Рубеж»"
    description="Аренда спецтехники с опытным оператором. Самосвалы, экскаваторы, бульдозеры, катки. Собственный автопарк 60+ единиц. Работаем по Архангельской области."
>
    <Header />

    <main>
        <PageHeader title="Аренда спецтехники" />

        <!-- Фильтры -->
        <section class="py-8 bg-white border-b border-zinc-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-wrap gap-3">
                    {categories.map((category) => (
                        <button
                            class={`filter-btn px-6 py-2 rounded font-semibold transition-colors cursor-pointer ${
                                category === "Все" 
                                    ? "bg-brand-dark text-white" 
                                    : "bg-zinc-100 text-zinc-700 hover:bg-zinc-200"
                            }`}
                            data-category={category}
                        >
                            {category}
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <!-- Каталог техники -->
        <section class="py-16 bg-zinc-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div id="equipment-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {equipment.map((item) => (
                        <EquipmentCard
                            title={item.title}
                            specs={item.specs}
                            category={item.category}
                            image={item.image}
                        />
                    ))}
                </div>
            </div>
        </section>

    </main>

    <Footer />

    <!-- Скрытый iframe для отправки в Google Apps Script -->
    <iframe name="gas-iframe" id="gas-iframe" class="hidden" tabindex="-1" aria-hidden="true"></iframe>
    <form id="gas-hidden-form" method="POST" target="gas-iframe" class="hidden" tabindex="-1">
        <input type="hidden" name="fio" />
        <input type="hidden" name="phone" />
        <input type="hidden" name="comment" />
        <input type="hidden" name="consent" />
    </form>

    <!-- Модальное окно формы заявки -->
    <div id="rental-modal" class="modal-overlay hidden">
        <div class="modal-container">
            <div class="modal-content rounded">
                <button
                    onclick="closeRentalModal()"
                    class="modal-close"
                    aria-label="Закрыть"
                >
                    <Icon name="lucide:x" class="w-5 h-5" />
                </button>
                
                <div class="mb-6">
                    <h2 class="text-2xl font-bold text-zinc-900 mb-2">Заявка на аренду</h2>
                    <p id="selected-equipment" class="text-brand-dark font-semibold"></p>
                </div>
                
                <LeadForm
                    formId="rental-form"
                    source="Аренда спецтехники"
                    submitLabel="Отправить заявку"
                    commentPlaceholder="Адрес объекта, дополнительные пожелания..."
                    fallbackPhone={contacts.mainPhoneDisplay}
                    onSuccessMessage="Заявка принята!"
                    onSuccessDescription="Наш менеджер свяжется с вами в ближайшее время для уточнения деталей."
                />
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    /* Модальное окно */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        z-index: 70;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    
    .modal-overlay.show {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }
    
    .modal-container {
        width: 100%;
        max-width: 600px;
        max-height: 90vh;
        overflow-y: auto;
        transform: scale(0.9);
        transition: transform 0.3s ease;
    }
    
    .modal-overlay.show .modal-container {
        transform: scale(1);
    }
    
    .modal-content {
        background: white;
        padding: 2rem;
        position: relative;
    }
    
    .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.5rem;
        background: transparent;
        border: none;
        color: #71717a;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    
    .modal-close:hover {
        background: #f4f4f5;
        color: #18181b;
    }
</style>

<script>
    type RentalWindow = Window & typeof globalThis & {
        openRentalForm: (button: HTMLButtonElement) => void;
        closeRentalModal: () => void;
    };

    const rentalWindow = window as RentalWindow;

    // Фильтрация техники
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const equipmentCards = document.querySelectorAll<HTMLElement>('.equipment-card');
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const category = btn.dataset.category;
            
            // Обновляем активную кнопку
            filterBtns.forEach(b => {
                b.classList.remove('bg-brand-dark', 'text-white');
                b.classList.add('bg-zinc-100', 'text-zinc-700');
            });
            btn.classList.remove('bg-zinc-100', 'text-zinc-700');
            btn.classList.add('bg-brand-dark', 'text-white');
            
            // Фильтруем карточки
            equipmentCards.forEach(card => {
                if (category === 'Все' || card.dataset.category === category) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    });
    
    // Открытие модального окна
    const modal = document.getElementById('rental-modal');

    rentalWindow.openRentalForm = function(button: HTMLButtonElement) {
        const equipmentName = button.dataset.equipment;
        const selectedEquipment = document.getElementById('selected-equipment');
        
        if (selectedEquipment && equipmentName) {
            selectedEquipment.textContent = equipmentName;
            
            // Добавляем название техники в комментарий формы
            const commentField = document.querySelector('#rental-form textarea[name="comment"]') as HTMLTextAreaElement;
            if (commentField) {
                commentField.placeholder = `Техника: ${equipmentName}. ${commentField.placeholder}`;
            }
        }
        
        if (modal) {
            modal.classList.remove('hidden');
            requestAnimationFrame(() => modal.classList.add('show'));
            document.body.style.overflow = 'hidden';
        }
    };
    
    // Закрытие модального окна
    rentalWindow.closeRentalModal = function() {
        if (modal) {
            const focused = document.activeElement;
            if (focused instanceof HTMLElement && modal.contains(focused)) {
                focused.blur();
            }
            modal.classList.remove('show');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }, 250);
        }
    };
    
    // Закрытие по клику вне модального окна
    document.getElementById('rental-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) {
            rentalWindow.closeRentalModal();
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal?.classList.contains('show')) {
            rentalWindow.closeRentalModal();
        }
    });
</script>
