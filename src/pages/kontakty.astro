---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import ContactForm from "../components/home/ContactForm.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import avitoIcon from "../assets/avito.svg";

const [contactsEntry] = (await getCollection("site")).sort((a, b) =>
    a.id.localeCompare(b.id),
);

if (!contactsEntry) {
    throw new Error("Site contacts content is missing in src/content/site.");
}

const contacts = contactsEntry.data;

// Мета-теги
const title = "Контакты дорожная компания (Архангельск) — ООО «Рубеж»";
const description = "Готовы обсудить условия подряда или аренды тяжелой техники? Свяжитесь с нами напрямую или посетите наш офис в Архангельске.";
---

<BaseLayout title={title} description={description}>
    <Header />
    
    <!-- Hero Contacts -->
    <PageHeader 
        title="Контакты"
        highlight=""
        subtitle=""
    >
        <!-- <p class="text-slate-400 text-lg md:text-xl leading-relaxed mb-4">
            Готовы обсудить условия подряда или аренды тяжелой техники? Чтобы связаться (Рубеж строительство) с нами напрямую или получить консультацию главного инженера, используйте удобный для вас способ связи или посетите наш офис.
        </p> -->
    </PageHeader>

    <!-- Основной блок (Контакты + Карта) -->
    <section class="py-16 bg-white relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
                
                <!-- Левая колонка: Контакты и Реквизиты -->
                <div class="space-y-12">
                    
                    <!-- Контакты -->
                    <div>
                        <h2 class="font-heading text-3xl md:text-4xl uppercase text-slate-900 mb-8 select-none">Наши координаты</h2>
                        
                        <div class="space-y-6">
                            <!-- Адрес -->
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center flex-shrink-0 text-blue-600 border border-slate-100">
                                    <Icon name="lucide:map-pin" class="w-6 h-6" />
                                </div>
                                <div>
                                    <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Наш офис</p>
                                    <p class="text-slate-800 font-medium text-lg">{contacts.addressShort}</p>
                                </div>
                            </div>
                            
                            <!-- Телефон -->
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center flex-shrink-0 text-blue-600 border border-slate-100">
                                    <Icon name="lucide:phone" class="w-6 h-6" />
                                </div>
                                <div>
                                    <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Бухгалтерия / Общие вопросы</p>
                                    <a href={`tel:${contacts.mainPhoneHref}`} class="text-slate-800 font-bold text-xl hover:text-blue-600 transition-colors">{contacts.mainPhoneDisplay}</a>
                                </div>
                            </div>
                            
                            <!-- Email -->
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center flex-shrink-0 text-blue-600 border border-slate-100">
                                    <Icon name="lucide:mail" class="w-6 h-6" />
                                </div>
                                <div>
                                    <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Электронная почта</p>
                                    <a href={`mailto:${contacts.officeEmail}`} class="text-slate-800 font-medium text-lg hover:text-blue-600 transition-colors">{contacts.officeEmail}</a>
                                </div>
                            </div>

                            <!-- Время работы -->
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center flex-shrink-0 text-blue-600 border border-slate-100">
                                    <Icon name="lucide:clock" class="w-6 h-6" />
                                </div>
                                <div>
                                    <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Режим работы</p>
                                    <p class="text-slate-800 font-medium">{contacts.workWeekdays}</p>
                                    <p class="text-slate-500 text-sm mt-1">{contacts.workWeekend}</p>
                                </div>
                            </div>
                            
                            <!-- Соцсети -->
                            <div class="flex gap-4 pt-4">
                                <a href={contacts.vkUrl} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white transition-all rounded-xl flex items-center justify-center group" aria-label="ВКонтакте">
                                    <Icon name="simple-icons:vk" class="w-5 h-5" />
                                </a>
                                <a href={contacts.avitoUrl} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white transition-all rounded-xl flex items-center justify-center group" aria-label="Avito">
                                    <Image src={avitoIcon} alt="Avito" width={20} height={20} loading="lazy" />
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Реквизиты (Для файлов) -->
                    <div class="bg-blue-50 border border-blue-100 p-6 md:p-8 rounded-2xl flex items-center justify-between">
                        <div>
                            <h3 class="font-heading text-2xl uppercase text-slate-900 mb-2">Реквизиты компании</h3>
                            <p class="text-slate-600 text-sm">{contacts.companyName}, ИНН {contacts.inn}</p>
                        </div>
                        <a href="/Rekvizity_OOO _RUBEZH.pdf" download class="w-14 h-14 bg-blue-600 hover:bg-slate-900 text-white transition-all rounded-xl flex items-center justify-center flex-shrink-0 group" aria-label="Скачать реквизиты">
                            <Icon name="lucide:download" class="w-6 h-6 transition-transform group-hover:-translate-y-1" />
                        </a>
                    </div>

                </div>

                <!-- Правая колонка: Яндекс Карта -->
                <div class="h-[500px] lg:h-auto min-h-[500px] bg-slate-100 rounded-3xl overflow-hidden relative shadow-lg border-4 border-white">
                    <!-- Placeholder до загрузки -->
                    <div id="map-placeholder" class="absolute inset-0 flex flex-col items-center justify-center gap-3">
                        <Icon name="lucide:map" class="w-12 h-12 text-slate-300" />
                        <p class="text-slate-400 text-sm font-semibold uppercase tracking-widest">Карта загружается...</p>
                    </div>

                    <iframe 
                        id="kontakty-map"
                        data-src={contacts.mapEmbedUrl}
                        src="" 
                        width="100%" 
                        height="100%" 
                        frameborder="0" 
                        allowfullscreen="true" 
                        class="absolute inset-0 w-full h-full border-0 opacity-0 transition-opacity duration-500"
                    >
                    </iframe>
                </div>

            </div>
        </div>
    </section>

    <!-- Секция формы -->
    <ContactForm />

    <Footer />
</BaseLayout>

<script>
    // Lazy loading карты
    const mapFrame = document.getElementById("kontakty-map") as HTMLIFrameElement;
    const mapPlaceholder = document.getElementById("map-placeholder") as HTMLElement;

    const mapObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting && mapFrame) {
                const src = mapFrame.dataset.src;
                if (src && mapFrame.getAttribute("src") !== src) {
                    mapFrame.setAttribute("src", src);
                    mapFrame.addEventListener("load", () => {
                        mapFrame.classList.remove("opacity-0");
                        mapFrame.classList.add("opacity-100");
                        mapPlaceholder?.classList.add("hidden");
                    }, { once: true });
                    mapObserver.unobserve(mapFrame);
                }
            }
        });
    }, { rootMargin: "200px" });

    if (mapFrame) mapObserver.observe(mapFrame);
</script>
