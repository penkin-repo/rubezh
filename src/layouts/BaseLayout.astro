---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "ООО Рубеж — Дорожное строительство и аренда спецтехники в Архангельске",
    description = "Дорожно-строительная компания ООО «Рубеж». Строительство дорог, аренда спецтехники, земляные работы в Архангельской области. 11+ лет опыта, 60+ единиц техники.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <!-- Preload hero image для LCP -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
    </head>
    <body>
        <slot />

        <div
            id="cookie-notice"
            class="cookie-notice hidden fixed left-4 right-4 bottom-4 z-[90] mx-auto max-w-3xl rounded border border-zinc-200 bg-white p-4 shadow-2xl"
            role="dialog"
            aria-live="polite"
            aria-label="Уведомление о cookies"
        >
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-sm text-zinc-600 leading-relaxed">
                    Мы используем cookie для корректной работы сайта. Продолжая
                    пользоваться сайтом, вы соглашаетесь с
                    <a href="/privacy" class="text-brand-dark underline hover:no-underline">
                        политикой конфиденциальности
                    </a>.
                </p>
                <button
                    id="cookie-accept"
                    type="button"
                    class="inline-flex items-center justify-center rounded bg-brand-dark px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-dark/90"
                >
                    Принять
                </button>
            </div>
        </div>

        <script>
            const COOKIE_KEY = "rubezh-cookies-accepted";
            const cookieNotice = document.getElementById("cookie-notice");
            const cookieAcceptBtn = document.getElementById("cookie-accept");

            const hideCookieNotice = () => {
                cookieNotice?.classList.add("hidden");
            };

            const showCookieNotice = () => {
                cookieNotice?.classList.remove("hidden");
            };

            try {
                const accepted = window.localStorage.getItem(COOKIE_KEY) === "1";
                if (!accepted) showCookieNotice();
            } catch {
                showCookieNotice();
            }

            cookieAcceptBtn?.addEventListener("click", () => {
                try {
                    window.localStorage.setItem(COOKIE_KEY, "1");
                } catch {
                    // ignore write errors
                }
                hideCookieNotice();
            });
        </script>
    </body>
</html>
