---
// src/components/ui/PageHeader.astro
import { Image } from "astro:assets";

interface Props {
  title: string;
  subtitle?: string;
  highlight?: string; // Слово для выделения синим цветом, если нужно
  image?: any; // Опциональное изображение справа
}

const { title, subtitle, highlight, image } = Astro.props;
---

<section
  class="pt-32 pb-8 md:pt-36 md:pb-12 bg-slate-900 relative overflow-hidden page-header-section border-b border-white/10"
>
  <!-- Фоновая сетка -->
  <div
    class="absolute inset-0 pointer-events-none header-bg-grid"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    {image ? (
      <div class="flex flex-col md:flex-row items-center justify-between gap-8 md:gap-12">
        <div class="flex-1 max-w-2xl">
          {subtitle && (
            <div class="flex items-center gap-3 mb-4">
              <div class="w-2 h-2 bg-brand-light rounded-full" />
              <span class="text-xs font-bold tracking-widest uppercase text-brand-light">
                {subtitle}
              </span>
            </div>
          )}
          <h1
            class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl uppercase text-white leading-none mb-4"
          >
            {title}
            {highlight && <span class="text-brand-light">{highlight}</span>}
          </h1>
          <slot />
        </div>
        <div class="w-full md:w-1/3 lg:w-[42%] flex-shrink-0 flex justify-center md:justify-end">
          <Image
            src={image}
            alt={title}
            widths={[400, 700, 1000]}
            sizes="(max-width: 768px) 100vw, 40vw"
            loading="eager"
            quality={80}
            class="w-full h-auto max-h-[220px] md:max-h-[300px] object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.15)]"
          />
        </div>
      </div>
    ) : (
      <div class="max-w-3xl">
        {subtitle && (
          <div class="flex items-center gap-3 mb-6">
            <div class="w-2 h-2 bg-brand-light rounded-full" />
            <span class="text-xs font-bold tracking-widest uppercase text-brand-light">
              {subtitle}
            </span>
          </div>
        )}
        <h1
          class="font-heading text-5xl md:text-6xl lg:text-7xl xl:text-8xl uppercase text-white mb-8 leading-none"
        >
          {title}
          {highlight && <span class="text-brand-light">{highlight}</span>}
        </h1>
        <slot />
      </div>
    )}
  </div>
</section>

<style>
  .page-header-section {
    background: linear-gradient(
      135deg,
      #0257c0 0%,
      #1e40af 20%,
      #3b82f6 45%,
      #f1f5f9 85%,
      #f8fafc 100%
    );
  }
  .header-bg-grid {
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style>
