---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import placeholder from '../../assets/services.png';

// 4 заглушка-проекта (будут заменены реальными фото через Keystatic)
const projects = [
  { id: 1, title: 'Ремонт муниципальной дороги', category: 'Дорожное строительство', location: 'Архангельск' },
  { id: 2, title: 'Благоустройство дворовой территории', category: 'Асфальтирование', location: 'Северодвинск' },
  { id: 3, title: 'Прокладка коммуникаций ГНБ', category: 'Инженерные сети', location: 'Архангельская обл.' },
  { id: 4, title: 'Земляные работы на объекте', category: 'Земляные работы', location: 'Архангельск' },
] as const;
---

<section class="py-24 bg-zinc-100" aria-labelledby="projects-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Заголовок -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-10 h-0.5 bg-brand-dark" aria-hidden="true"></span>
          <span class="text-brand-dark text-xs font-semibold tracking-widest uppercase">Портфолио</span>
        </div>
        <h2 id="projects-heading"
            class="font-heading text-zinc-900 uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide">
          Наши работы
        </h2>
      </div>
      <a href="/projects"
         class="inline-flex items-center gap-2 text-sm font-semibold text-brand-dark
                hover:text-brand-light transition-colors duration-200 self-end">
        Все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <!-- Сетка 2×2 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((project) => (
        <button
          class="project-item group relative overflow-hidden rounded-2xl aspect-[4/3] cursor-zoom-in text-left"
          data-id={project.id}
          data-title={project.title}
          data-category={project.category}
          data-location={project.location}
          aria-label={`Открыть проект: ${project.title}`}
        >
          <!-- Фото -->
          <Image
            src={placeholder}
            alt={project.title}
            widths={[400, 700, 900]}
            sizes="(max-width: 640px) 100vw, 50vw"
            loading="lazy"
            quality={85}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />

          <!-- Overlay -->
          <div class="project-overlay absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent
                      opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex flex-col justify-end p-6">
            <div class="flex items-start justify-between">
              <div>
                <span class="text-brand-light text-xs font-semibold tracking-widest uppercase block mb-1">
                  {project.category}
                </span>
                <h3 class="font-heading text-white uppercase text-xl lg:text-2xl leading-tight">
                  {project.title}
                </h3>
                <p class="text-slate-300 text-sm mt-1 flex items-center gap-1">
                  <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
                  {project.location}
                </p>
              </div>
              <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center
                          border border-white/30 flex-shrink-0 mt-auto">
                <Icon name="lucide:zoom-in" class="w-5 h-5 text-white" />
              </div>
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/projects"
         class="inline-flex items-center gap-2 px-8 py-4 rounded-xl uppercase tracking-wide
                text-white bg-brand-dark hover:bg-brand-light transition-colors duration-300 text-sm">
        Смотреть все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

<!-- Native Lightbox -->
<dialog id="project-lightbox" class="lightbox-dialog p-0 max-w-4xl w-full bg-transparent">
  <div class="lightbox-inner relative bg-zinc-900 rounded-2xl overflow-hidden shadow-2xl">
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 z-20 w-10 h-10 rounded-full bg-black/50 backdrop-blur-sm
             border border-white/20 flex items-center justify-center text-white
             hover:bg-white/20 transition-colors"
      aria-label="Закрыть"
    >
      <Icon name="lucide:x" class="w-5 h-5" />
    </button>

    <Image
      src={placeholder}
      alt=""
      widths={[800, 1200]}
      sizes="90vw"
      loading="lazy"
      quality={90}
      id="lightbox-img"
      class="w-full aspect-video object-cover"
    />
    <div class="p-6">
      <p id="lightbox-category" class="text-brand-light text-xs font-semibold tracking-widest uppercase mb-1"></p>
      <h3 id="lightbox-title" class="font-heading text-white uppercase text-2xl leading-tight"></h3>
      <p id="lightbox-location" class="text-slate-400 text-sm mt-1 flex items-center gap-1.5">
        <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
        <span></span>
      </p>
    </div>
  </div>
</dialog>

<style>
  /* Lightbox dialog стили — нельзя через Tailwind (нет утилит ::backdrop) */
  .lightbox-dialog {
    border: none;
    border-radius: 1rem;
    background: transparent;
    max-height: 90vh;
    overflow: hidden;
  }
  .lightbox-dialog::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
  }
  .lightbox-dialog[open] {
    display: block;
    animation: lightbox-in 0.3s ease both;
  }
  @keyframes lightbox-in {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }

  .project-overlay {
    transition: opacity 0.35s ease;
  }
</style>

<script>
  const dialog   = document.getElementById('project-lightbox') as HTMLDialogElement;
  const closeBtn = document.getElementById('lightbox-close');
  const titleEl  = document.getElementById('lightbox-title');
  const catEl    = document.getElementById('lightbox-category');
  const locEl    = document.getElementById('lightbox-location')?.querySelector('span');

  // Открытие по клику на карточку
  document.querySelectorAll<HTMLElement>('.project-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (titleEl) titleEl.textContent = btn.dataset.title ?? '';
      if (catEl)   catEl.textContent   = btn.dataset.category ?? '';
      if (locEl)   locEl.textContent   = btn.dataset.location ?? '';
      dialog?.showModal();
    });
  });

  // Закрытие
  closeBtn?.addEventListener('click', () => dialog?.close());
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });
</script>
