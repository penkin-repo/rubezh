---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---

<section class="py-16 md:py-24 bg-zinc-100" aria-labelledby="projects-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Заголовок -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
      <div>
        <!-- <div class="flex items-center gap-3 mb-4">
          <span class="w-10 h-0.5 bg-brand-dark" aria-hidden="true"></span>
          <span class="text-brand-dark text-xs font-semibold tracking-widest uppercase">Проекты</span>
        </div> -->
        <h2 id="projects-heading"
            class="font-heading text-zinc-900 uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide">
          Проекты
        </h2>
      </div>
      <a href="/proekty"
         class="inline-flex items-center gap-2 text-sm font-semibold text-brand-dark
                hover:text-brand-light transition-colors duration-200 self-end">
        Все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <!-- Сетка 2×2 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {projects.map((project) => (
        <article class="project-gallery">
          <!-- Главная обложка -->
          <a
            href={project.data.images[0].src}
            data-pswp-width={project.data.images[0].width}
            data-pswp-height={project.data.images[0].height}
            data-pswp-caption={`<div class=\"pswp-caption-inner\"><h4>${project.data.title}</h4><p>${project.data.description}</p></div>`}
            target="_blank"
            class="project-item group relative overflow-hidden rounded aspect-[4/3] cursor-zoom-in text-left block"
            aria-label={`Открыть проект: ${project.data.title}`}
          >
            <!-- Фото -->
            <Image
              src={project.data.images[0]}
              alt={project.data.title}
              widths={[400, 700]}
              sizes="(max-width: 640px) 400px, 700px"
              loading="lazy"
              quality={75}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />

            <div class="absolute inset-0 bg-black/35 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute right-3 top-3 rounded bg-white/90 px-2.5 py-1 text-xs font-semibold text-zinc-900
                        opacity-0 transition-all duration-300 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0
                        flex items-center gap-1.5">
              <Icon name="lucide:images" class="w-3.5 h-3.5" />
              {project.data.images.length} фото
            </div>
            <div class="absolute left-3 bottom-3 rounded bg-black/70 px-2.5 py-1 text-[11px] font-medium text-white
                        opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              Открыть галерею
            </div>
          </a>
          
          <div class="mt-2">
            <h3 class="text-zinc-900 text-center uppercase text-xl leading-tight">
              {project.data.title}
            </h3>
          </div>

          <!-- Скрытые фотографии проекта для галереи -->
          {project.data.images.slice(1).map((img) => (
            <a
              href={img.src}
              data-pswp-width={img.width}
              data-pswp-height={img.height}
              data-pswp-caption={`<div class=\"pswp-caption-inner\"><h4>${project.data.title}</h4><p>${project.data.description}</p></div>`}
              target="_blank"
              class="hidden"
            >
              <Image 
                src={img} 
                alt={`${project.data.title} фото`} 
                width={img.width > 1200 ? 1200 : img.width}
                loading="lazy" 
                quality={80} 
              />
            </a>
          ))}
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/proekty"
         class="inline-flex items-center gap-2 px-8 py-4 rounded uppercase tracking-wide
                text-white bg-brand-dark hover:bg-brand-light transition-colors duration-300 text-sm">
        Смотреть все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

<script>
  import { initPhotoSwipe } from '../../scripts/photoswipe-init';

  // Динамическая инициализация при первом клике
  const galleries = document.querySelectorAll('.project-gallery');
  let isInitialized = false;

  galleries.forEach(gallery => {
    gallery.addEventListener('click', async (e) => {
      if (!isInitialized) {
        const target = e.target as HTMLElement;
        if (target.closest('a')) {
          e.preventDefault();
          await initPhotoSwipe({
            gallery: '.project-gallery',
            children: 'a',
          });
          isInitialized = true;
          // Повторный клик после инициализации
          setTimeout(() => target.closest('a')?.click(), 100);
        }
      }
    }, { once: true });
  });
</script>
