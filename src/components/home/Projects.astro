---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---

<section class="py-24 bg-zinc-100" aria-labelledby="projects-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Заголовок -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-10 h-0.5 bg-brand-dark" aria-hidden="true"></span>
          <span class="text-brand-dark text-xs font-semibold tracking-widest uppercase">Портфолио</span>
        </div>
        <h2 id="projects-heading"
            class="font-heading text-zinc-900 uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide">
          Наши работы
        </h2>
      </div>
      <a href="/projects"
         class="inline-flex items-center gap-2 text-sm font-semibold text-brand-dark
                hover:text-brand-light transition-colors duration-200 self-end">
        Все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <!-- Сетка 2×2 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((project) => (
        <div class="project-gallery">
          <!-- Главная обложка -->
          <a
            href={project.data.images[0].src}
            data-pswp-width={project.data.images[0].width}
            data-pswp-height={project.data.images[0].height}
            target="_blank"
            class="project-item group relative overflow-hidden rounded-2xl aspect-[4/3] cursor-zoom-in text-left block"
            aria-label={`Открыть проект: ${project.data.title}`}
          >
            <!-- Фото -->
            <Image
              src={project.data.images[0]}
              alt={project.data.title}
              widths={[400, 700, 900]}
              sizes="(max-width: 640px) 100vw, 50vw"
              loading="lazy"
              quality={85}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />

            <!-- Overlay (Always visible) -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent flex flex-col justify-end p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-heading text-white uppercase text-xl lg:text-2xl leading-tight">
                    {project.data.title}
                  </h3>
                  <p class="text-slate-300 text-sm mt-1 flex items-center gap-1">
                    <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
                    {project.data.location}
                  </p>
                </div>
                <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center
                            border border-white/30 flex-shrink-0 mt-auto">
                  <Icon name="lucide:camera" class="w-5 h-5 text-white" />
                  <span class="absolute -top-2 -right-2 bg-brand-light text-brand-dark text-[10px] font-bold px-1.5 py-0.5 rounded-full">
                    {project.data.images.length}
                  </span>
                </div>
              </div>
            </div>
          </a>

          <!-- Скрытые фотографии проекта для галереи -->
          {project.data.images.slice(1).map((img) => (
            <a
              href={img.src}
              data-pswp-width={img.width}
              data-pswp-height={img.height}
              target="_blank"
              class="hidden"
            >
              <Image 
                src={img} 
                alt={`${project.data.title} фото`} 
                width={img.width > 1200 ? 1200 : img.width}
                loading="lazy" 
                quality={80} 
              />
            </a>
          ))}
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/projects"
         class="inline-flex items-center gap-2 px-8 py-4 rounded-xl uppercase tracking-wide
                text-white bg-brand-dark hover:bg-brand-light transition-colors duration-300 text-sm">
        Смотреть все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

<style>
  /* Кастомизация PhotoSwipe под стилистику сайта */
  :global(.pswp__bg) {
    background: rgba(0, 0, 0, 0.9) !important;
    backdrop-filter: blur(8px);
  }
  :global(.pswp__top-bar) {
    background: transparent !important;
  }
  :global(.pswp__counter) {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 14px;
    letter-spacing: 0.05em;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.project-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    
    // UI опции 2026
    bgOpacity: 0.9,
    padding: { top: 20, bottom: 20, left: 20, right: 20 },
    wheelToZoom: true,
    showHideAnimationType: 'zoom',
  });
  
  lightbox.init();
</script>
