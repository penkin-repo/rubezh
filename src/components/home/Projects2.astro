---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { getProjectImages } from '../../utils/project-images';

const allWorkImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/works/**/*.{png,jpg,jpeg,webp,PNG,JPG,JPEG,WEBP}',
  { eager: true }
);

const allProjects = await getCollection('projects2');
const sorted = allProjects.sort((a, b) => {
  if (a.data.year !== b.data.year) return b.data.year - a.data.year;
  return a.data.order - b.data.order;
});

const years = [...new Set(sorted.map((p) => p.data.year))].sort((a, b) => b - a);

const HOME_LIMIT = 2;
const projectsByYear: Record<number, typeof sorted> = {};
const allProjectsByYear: Record<number, typeof sorted> = {};
for (const year of years) {
  const yearProjects = sorted.filter((p) => p.data.year === year);
  allProjectsByYear[year] = yearProjects;
  projectsByYear[year] = yearProjects.slice(0, HOME_LIMIT);
}

const imageCache = new Map<string, ImageMetadata[]>();
for (const p of sorted) {
  imageCache.set(p.data.imageFolder, getProjectImages(allWorkImages, p.data.imageFolder));
}
---

<section class="py-16 md:py-24 bg-zinc-100" aria-labelledby="projects2-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Заголовок -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-10">
      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-brand-dark mb-2">Проекты 2</p>
        <h2 id="projects2-heading"
            class="font-heading text-zinc-900 uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide">
          Проекты
        </h2>
      </div>
      <a href="/proekty2"
         class="inline-flex items-center gap-2 text-sm font-semibold text-brand-dark
                hover:text-brand-light transition-colors duration-200 self-end">
        Все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <!-- Вкладки по годам -->
    <div class="flex flex-wrap gap-3 mb-10">
      {years.map((year, i) => (
        <button
          class={`year-tab px-6 py-2.5 rounded font-semibold text-sm transition-colors cursor-pointer ${
            i === 0
              ? 'bg-brand-dark text-white'
              : 'bg-white text-zinc-700 hover:bg-zinc-200 border border-zinc-200'
          }`}
          data-year={year}
        >
          {year} г.
        </button>
      ))}
    </div>

    <!-- Контент по годам -->
    {years.map((year, yearIdx) => (
      <div class={`year-content space-y-8 ${yearIdx === 0 ? '' : 'hidden'}`} data-year-content={year}>
        {projectsByYear[year].map((project, idx) => {
          const images = imageCache.get(project.data.imageFolder) || [];
          const hasImages = images.length > 0;
          return (
          <article
            class={`project2-gallery bg-white rounded overflow-hidden shadow-sm border border-zinc-100 hover:shadow-md transition-shadow duration-300`}
          >
            <div class="flex flex-col md:flex-row">
              {hasImages ? (
              <a
                href={images[0].src}
                data-pswp-width={images[0].width}
                data-pswp-height={images[0].height}
                target="_blank"
                class="project2-cover md:w-2/5 lg:w-[45%] flex-shrink-0 relative group cursor-zoom-in block"
                aria-label={`Открыть галерею: ${project.data.title}`}
              >
                <div class="aspect-[4/3] overflow-hidden">
                  <Image
                    src={images[0]}
                    alt={project.data.title}
                    widths={[400, 600]}
                    sizes="(max-width: 768px) 100vw, 45vw"
                    loading="lazy"
                    quality={75}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
                <div class="absolute right-3 top-3 rounded bg-white/90 px-2.5 py-1 text-xs font-semibold text-zinc-900
                            opacity-0 transition-all duration-300 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0
                            flex items-center gap-1.5 shadow-sm">
                  <Icon name="lucide:images" class="w-3.5 h-3.5" />
                  {images.length} фото
                </div>
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <span class="bg-white/90 rounded px-3 py-1.5 text-xs font-semibold text-zinc-900 shadow-sm">
                    Открыть галерею
                  </span>
                </div>
              </a>
              ) : (
              <div class="md:w-2/5 lg:w-[45%] flex-shrink-0">
                <div class="aspect-[4/3] bg-zinc-100 flex flex-col items-center justify-center text-zinc-400">
                  <Icon name="lucide:image-off" class="w-10 h-10 mb-2" />
                  <span class="text-xs font-medium">Фото скоро</span>
                </div>
              </div>
              )}

              <!-- Текст справа -->
              <div class="flex-1 p-5 md:p-6 lg:p-8 flex flex-col justify-center">
                <h3 class="font-heading text-zinc-900 uppercase text-xl sm:text-2xl leading-tight mb-4">
                  {project.data.title}
                </h3>

                <div class="space-y-3 text-sm">
                  <div class="flex gap-3">
                    <div class="flex-shrink-0 w-5 h-5 mt-0.5 text-brand-dark">
                      <Icon name="lucide:hard-hat" class="w-5 h-5" />
                    </div>
                    <div>
                      <span class="font-semibold text-zinc-500 uppercase text-xs tracking-wide">Виды работ</span>
                      <p class="text-zinc-700 mt-0.5 leading-relaxed">{project.data.works}</p>
                    </div>
                  </div>

                  <div class="flex gap-3">
                    <div class="flex-shrink-0 w-5 h-5 mt-0.5 text-brand-dark">
                      <Icon name="lucide:building-2" class="w-5 h-5" />
                    </div>
                    <div>
                      <span class="font-semibold text-zinc-500 uppercase text-xs tracking-wide">Заказчик</span>
                      <p class="text-zinc-900 font-medium mt-0.5">{project.data.client}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Скрытые фото для галереи -->
            {images.slice(1).map((img) => (
              <a
                href={img.src}
                data-pswp-width={img.width}
                data-pswp-height={img.height}
                target="_blank"
                class="hidden"
              >
                <Image
                  src={img}
                  alt={`${project.data.title} фото`}
                  width={img.width > 1200 ? 1200 : img.width}
                  loading="lazy"
                  quality={75}
                />
              </a>
            ))}
          </article>
          );
        })}
      </div>
    ))}

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/proekty2"
         class="inline-flex items-center gap-2 px-8 py-4 rounded uppercase tracking-wide
                text-white bg-brand-dark hover:bg-brand-light transition-colors duration-300 text-sm">
        Смотреть все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

<style>
  @import '../../styles/photoswipe-custom.css';
</style>

<script>
  import { initPhotoSwipe } from '../../scripts/photoswipe-init';

  // Вкладки по годам
  const tabs = document.querySelectorAll<HTMLButtonElement>('.year-tab');
  const contents = document.querySelectorAll<HTMLElement>('.year-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const year = tab.dataset.year;

      tabs.forEach(t => {
        t.classList.remove('bg-brand-dark', 'text-white');
        t.classList.add('bg-white', 'text-zinc-700', 'border', 'border-zinc-200');
      });
      tab.classList.remove('bg-white', 'text-zinc-700', 'border', 'border-zinc-200');
      tab.classList.add('bg-brand-dark', 'text-white');

      contents.forEach(c => {
        if (c.dataset.yearContent === year) {
          c.classList.remove('hidden');
        } else {
          c.classList.add('hidden');
        }
      });
    });
  });

  // PhotoSwipe для всех галерей
  initPhotoSwipe({
    gallery: '.project2-gallery',
    children: 'a',
  });
</script>
