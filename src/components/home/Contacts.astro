---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import avitoIcon from "../../assets/avito.svg";
import { Image } from "astro:assets";
// Данные: PROJECT_LOG_HOW.md — контакты компании

const [contactsEntry] = (await getCollection("site")).sort((a, b) =>
    a.id.localeCompare(b.id),
);

if (!contactsEntry) {
    throw new Error("Site contacts content is missing in src/content/site.");
}

const contacts = contactsEntry.data;
---

<section
    class="contacts-section relative overflow-hidden py-16 md:py-24 bg-slate-900"
    aria-labelledby="contacts-heading"
>
    <!-- Фоновый паттерн -->
    <div
        class="absolute inset-0 pointer-events-none contacts-bg-grid"
        aria-hidden="true"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Заголовок -->
        <div class="mb-12">
            <!-- <div class="flex items-center gap-3 mb-4">
                <span class="w-10 h-0.5 bg-brand-light" aria-hidden="true"
                ></span>
                <span
                    class="text-brand-light text-xs font-semibold tracking-widest uppercase"
                    >Где нас найти</span
                >
            </div> -->
            <h2
                id="contacts-heading"
                class="font-heading text-center text-white uppercase text-3xl sm:text-4xl leading-none tracking-wide"
            >
                Контакты
            </h2>
        </div>

        <!-- Split layout: контакты + карта -->
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
            <!-- Левая: контактная информация -->
            <div class="space-y-6">
                <!-- Адрес -->
                <div class="contact-card flex gap-4">
                    <div
                        class="w-12 h-12 rounded bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0"
                    >
                        <Icon
                            name="lucide:map-pin"
                            class="w-5 h-5 text-brand-light"
                        />
                    </div>
                    <div>
                        <p
                            class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-1"
                        >
                            Адрес
                        </p>
                        <p class="text-white font-medium leading-snug">
                            {contacts.addressFull}
                        </p>
                    </div>
                </div>

                <!-- Телефон -->
                <div class="contact-card flex gap-4">
                    <div
                        class="w-12 h-12 rounded bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0"
                    >
                        <Icon
                            name="lucide:phone"
                            class="w-5 h-5 text-brand-light"
                        />
                    </div>
                    <div>
                        <p
                            class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-1"
                        >
                            Главный бухгалтер
                        </p>
                        <a
                            href={`tel:${contacts.mainPhoneHref}`}
                            class="text-white font-semibold text-lg hover:text-brand-light transition-colors duration-200"
                        >
                            {contacts.mainPhoneDisplay}
                        </a>
                    </div>
                </div>

                <!-- Email -->
                <div class="contact-card flex gap-4">
                    <div
                        class="w-12 h-12 rounded bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0"
                    >
                        <Icon name="lucide:mail" class="w-5 h-5 text-brand-light" />
                    </div>
                    <div>
                        <p
                            class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-1"
                        >
                            Email (офис)
                        </p>
                        <a
                            href={`mailto:${contacts.officeEmail}`}
                            class="text-white hover:text-brand-light transition-colors duration-200"
                        >
                            {contacts.officeEmail}
                        </a>
                    </div>
                </div>

                <!-- HR -->
                <div class="contact-card flex gap-4">
                    <div
                        class="w-12 h-12 rounded bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0"
                    >
                        <Icon
                            name="lucide:users"
                            class="w-5 h-5 text-brand-light"
                        />
                    </div>
                    <div>
                        <p
                            class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-1"
                        >
                            Отдел кадров (вакансии)
                        </p>
                        <a
                            href={`tel:${contacts.hrPhoneHref}`}
                            class="text-white hover:text-brand-light transition-colors duration-200 block"
                        >
                            {contacts.hrPhoneDisplay}
                        </a>
                        <a
                            href={`mailto:${contacts.hrEmail}`}
                            class="text-white/70 hover:text-brand-light transition-colors duration-200 text-sm"
                        >
                            {contacts.hrEmail}
                        </a>
                    </div>
                </div>

                <!-- ВКонтакте -->
                <div class="contact-card flex gap-4">
                    <div
                        class="w-12 h-12 rounded bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0"
                    >
                        <Icon name="simple-icons:vk" class="w-5 h-5 text-brand-light" />
                    </div>
                    <div>
                        <p
                            class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-1"
                        >
                            ВКонтакте
                        </p>
                        <a
                            href={contacts.vkUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-white hover:text-brand-light transition-colors duration-200"
                        >
                            Страница ВКонтакте
                        </a>
                    </div>
                </div>

                <!-- Avito -->
                <div class="contact-card flex gap-4">
                    <div
                        class="w-12 h-12 rounded bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0"
                    >
                        <Image
                            src={avitoIcon}
                            alt="Avito"
                            width={20}
                            height={20}
                            loading="lazy"
                        />
                    </div>
                    <div>
                        <p
                            class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-1"
                        >
                            Avito
                        </p>
                        <a
                            href={contacts.avitoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-white hover:text-brand-light transition-colors duration-200"
                        >
                            Профиль Avito
                        </a>
                    </div>
                </div>

                <!-- Режим работы -->
                <div
                    class="mt-8 p-5 rounded bg-white/5 border border-white/10"
                >
                    <p
                        class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-3"
                    >
                        Режим работы
                    </p>
                    <div class="space-y-1">
                        <p class="text-white text-sm flex justify-between">
                            <span class="text-white/80">{contacts.workWeekdays}</span>
                        </p>
                        <p class="text-white text-sm flex justify-between">
                            <span class="text-white/50">{contacts.workWeekend}</span>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Правая: Яндекс.Карта (lazy-loaded) -->
            <div
                class="relative rounded overflow-hidden min-h-[400px] lg:min-h-0 bg-zinc-800"
            >
                <!-- Placeholder до загрузки -->
                <div
                    id="map-placeholder"
                    class="absolute inset-0 flex flex-col items-center justify-center gap-3"
                >
                    <Icon name="lucide:map" class="w-12 h-12 text-zinc-600" />
                    <p class="text-zinc-500 text-sm">Карта загружается...</p>
                </div>

                <!-- iframe с lazy loading -->
                <iframe
                    id="yandex-map"
                    title="Местоположение ООО Рубеж на карте"
                    src=""
                    data-src={contacts.mapEmbedUrl}
                    class="absolute inset-0 w-full h-full border-0 opacity-0 transition-opacity duration-500"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</section>

<style>
    .contacts-section {
        background-color: #080e1c;
    }
    .contacts-bg-grid {
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }
</style>

<script>
    // Lazy loading карты — загружаем iframe только когда секция видна
    const mapFrame = document.getElementById("yandex-map") as HTMLIFrameElement;
    const mapPlaceholder = document.getElementById(
        "map-placeholder",
    ) as HTMLElement;

    const mapObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting && mapFrame) {
                    const src = mapFrame.dataset.src;
                    if (src && mapFrame.getAttribute("src") !== src) {
                        mapFrame.setAttribute("src", src);
                        mapFrame.addEventListener(
                            "load",
                            () => {
                                mapFrame.style.opacity = "1";
                                mapPlaceholder?.classList.add("hidden");
                            },
                            { once: true },
                        );
                        mapObserver.unobserve(mapFrame);
                    }
                }
            });
        },
        { rootMargin: "200px" },
    );

    if (mapFrame) mapObserver.observe(mapFrame);
</script>
