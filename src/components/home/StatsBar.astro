---
const stats = [
    { value: 11, suffix: "+", label: "лет работы" },
    { value: 200, suffix: "+", label: "объектов" },
    { value: 60, suffix: "+", label: "единиц техники" },
    { value: 130, suffix: "+", label: "специалистов" },
] as const;
---

<div class="stats-bar w-full py-10 px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-wrap justify-center gap-6 lg:gap-8">
            {
                stats.map((stat, i) => (
                    <div
                        class="stat-card group flex-1 min-w-[140px] max-w-[220px] flex flex-col items-center justify-center
                               py-8 px-6 rounded
                               border-1 border-white/70
                               bg-black/30
                               text-center
                               transition-transform duration-300 hover:-translate-y-1"
                        data-target={stat.value}
                        data-index={i}
                    >
                        <!-- Число + суффикс -->
                        <div class="flex items-end justify-center leading-none mb-3">
                            <span
                                class="stat-number font-heading text-5xl sm:text-6xl text-white"
                                data-target={stat.value}
                            >
                                0
                            </span>
                            <span class="font-heading text-5xl sm:text-6xl text-blue-400 ml-0.5">
                                {stat.suffix}
                            </span>
                        </div>
                        <!-- Подпись -->
                        <div class="font-body text-white/70 text-xs sm:text-sm uppercase tracking-widest">
                            {stat.label}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</div>

<script>
    // Count-up анимация при попадании в viewport
    function easeOutQuart(t: number): number {
        return 1 - Math.pow(1 - t, 4);
    }

    function animateCount(el: HTMLElement, target: number, duration: number = 1400) {
        const start = performance.now();

        function update(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const current = Math.round(easeOutQuart(progress) * target);
            el.textContent = String(current);
            if (progress < 1) requestAnimationFrame(update);
        }

        requestAnimationFrame(update);
    }

    // IntersectionObserver — запускаем счётчики когда карточки входят в поле видимости
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                const card = entry.target as HTMLElement;
                const target = parseInt(card.dataset.target ?? "0", 10);
                const numberEl = card.querySelector<HTMLElement>(".stat-number");
                if (!numberEl) return;

                // Небольшая задержка по индексу для "очереди"
                const index = parseInt(card.dataset.index ?? "0", 10);
                setTimeout(() => animateCount(numberEl, target), index * 120);

                observer.unobserve(card); // запустить счётчик только один раз
            });
        },
        { threshold: 0.4 }
    );

    document.querySelectorAll<HTMLElement>(".stat-card").forEach((card) => {
        observer.observe(card);
    });

    // Scale-анимация при появлении в viewport
    const scaleObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                const card = entry.target as HTMLElement;
                if (entry.isIntersecting) {
                    const idx = parseInt(card.dataset.index ?? "0", 10);
                    setTimeout(() => {
                        card.style.transform = "scale(1) translateY(0)";
                        card.style.opacity = "1";
                    }, idx * 100);
                }
            });
        },
        { threshold: 0.2 }
    );

    document.querySelectorAll<HTMLElement>(".stat-card").forEach((card) => {
        // Начальное состояние: сжаты и прозрачны
        card.style.transform = "scale(0.88) translateY(20px)";
        card.style.opacity = "0";
        card.style.transition = "transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease";
        scaleObserver.observe(card);
    });
</script>
