---
import { Image } from "astro:assets";

interface Props {
    id: string;
    title: string;
    desc: string;
    fullDesc: string;
    image?: ImageMetadata;
    videoSrc?: string;
}

const { id, title, desc, fullDesc, image, videoSrc } = Astro.props;

// Разделяем описание на абзацы. Первый абзац пойдет ДО картинки, остальные — ПОСЛЕ.
const paragraphs = fullDesc.split("\n\n").filter((p) => p.trim() !== "");
const firstParagraph = paragraphs[0];
const remainingParagraphs = paragraphs.slice(1);
---

<dialog
    id={`modal-${id}`}
    class="service-modal p-0 m-auto bg-transparent border-none w-[calc(100%-2rem)] max-w-3xl backdrop:backdrop-blur-sm backdrop:bg-slate-900/60 opacity-0 transition-opacity duration-300 open:opacity-100"
>
    <!-- Основной контейнер -->
    <div
        class="bg-white w-full rounded-2xl flex flex-col relative transform transition-all duration-500 scale-95 opacity-0 modal-content shadow-2xl overflow-hidden max-h-[90vh]"
    >
        <!-- Кнопка закрытия (фиксирована поверх контента) -->
        <button
            class="js-close-modal absolute top-3 right-3 md:top-4 md:right-4 z-50 bg-slate-100/90 hover:bg-slate-200 backdrop-blur p-2 rounded-full transition-colors text-slate-700 group"
            aria-label="Закрыть"
            data-modal={id}
        >
            <svg
                class="w-6 h-6 transition-transform group-hover:rotate-90"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <!-- Скроллируемая область внутри модалки -->
        <div class="overflow-y-auto w-full max-h-[90vh] custom-scroll relative">
            <article class="px-6 py-10 md:p-12 text-left">
                <!-- Заголовок -->
                <h3
                    class="font-heading text-3xl md:text-5xl uppercase text-slate-900 mb-6 leading-none pr-10"
                >
                    {title}
                </h3>

                <!-- Вводный жирный текст -->
                <p class="text-slate-800 font-bold text-lg leading-snug mb-6">
                    {desc}
                </p>

                <!-- Первый абзац -->
                {
                    firstParagraph && (
                        <p class="text-slate-700 mb-8 text-base md:text-lg leading-relaxed">
                            {firstParagraph}
                        </p>
                    )
                }

                <!-- Медиа-вставка (видео или фото) -->
                <div
                    class="w-full relative bg-slate-100 rounded-xl overflow-hidden mb-8 aspect-video border border-slate-100 shadow-sm"
                >
                    {
                        // https://vkvideo.ru/video-64387052_456266313?sh=4
                        // https://vk.com/video-64387052_456266313
                        // <iframe src="https://vkvideo.ru/video_ext.php?oid=-64387052&id=456266313&hash=324cc1326e20bff9&hd=4" width="1920" height="1080" allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;" frameborder="0" allowfullscreen></iframe>
                        videoSrc ? (
                            <video
                                class="absolute inset-0 w-full h-full object-cover"
                                src={videoSrc}
                                controls
                                playsinline
                            />
                        ) : image ? (
                            <Image
                                src={image}
                                alt={title}
                                widths={[640, 1024]}
                                sizes="(max-width: 768px) 100vw, 800px"
                                class="absolute inset-0 w-full h-full object-cover"
                            />
                        ) : null
                    }
                </div>

                <!-- Оставшиеся абзацы текста -->
                {
                    remainingParagraphs.length > 0 && (
                        <div class="text-slate-700 text-base md:text-lg leading-relaxed space-y-5">
                            {remainingParagraphs.map((p) => (
                                <p>{p}</p>
                            ))}
                        </div>
                    )
                }
            </article>
        </div>
    </div>
</dialog>

<style>
    /* Отключаем синюю рамку при фокусе */
    dialog:focus-visible {
        outline: none;
    }

    /* Анимации при открытии */
    dialog[open] .modal-content {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    /* Кастомный скроллбар для внутреннего контента */
    .custom-scroll::-webkit-scrollbar {
        width: 8px;
    }
    .custom-scroll::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scroll::-webkit-scrollbar-thumb {
        background-color: #cbd5e1; /* slate-300 */
        border-radius: 20px;
        border: 2px solid #ffffff;
    }
    .custom-scroll::-webkit-scrollbar-thumb:hover {
        background-color: #94a3b8; /* slate-400 */
    }
</style>
