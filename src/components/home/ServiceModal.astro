---
import { Image } from "astro:assets";

interface Props {
    id: string;
    title: string;
    desc: string;
    hideModalImage?: boolean;
    image?: ImageMetadata;
    videoEmbedUrl?: string;
}

const { id, title, desc, hideModalImage, image, videoEmbedUrl } = Astro.props;
---

<dialog
    id={`modal-${id}`}
    class="service-modal p-0 m-auto bg-transparent border-none w-[calc(100%-2rem)] max-w-5xl backdrop:backdrop-blur-sm backdrop:bg-slate-900/60 opacity-0 transition-opacity duration-300 open:opacity-100"
>
    <!-- Основной контейнер -->
    <div
        class="bg-white w-full rounded flex flex-col relative transform transition-all duration-500 scale-95 opacity-0 modal-content shadow-2xl overflow-hidden max-h-[90vh]"
    >
        <!-- Кнопка закрытия (фиксирована поверх контента) -->
        <button
            class="js-close-modal absolute top-3 right-3 md:top-4 md:right-4 z-50 bg-slate-100/90 hover:bg-slate-200 backdrop-blur p-2 rounded transition-colors text-slate-700 group"
            aria-label="Закрыть"
            data-modal={id}
        >
            <svg
                class="w-6 h-6 transition-transform group-hover:rotate-90"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <!-- Скроллируемая область внутри модалки -->
        <div class="overflow-y-auto w-full max-h-[90vh] custom-scroll relative">
            <article class="px-6 py-10 md:p-12 text-left">
                <!-- Заголовок -->

                <h3
                    class="font-heading text-3xl md:text-5xl uppercase text-slate-900 mb-4 leading-none pr-10"
                >
                    {title}
                </h3>

                <!-- Вводный текст -->
                <p class="text-slate-600 text-lg leading-snug mb-8">
                    {desc}
                </p>

                <!-- Медиа-вставка: VK iframe или фото -->

                {
                    hideModalImage ? null : image ? (
                        <div class="w-full relative bg-slate-100 rounded overflow-hidden mb-8 aspect-video border border-slate-100 shadow-sm">
                            <Image
                                src={image}
                                alt={title}
                                widths={[640, 1024, 1400]}
                                sizes="(max-width: 768px) 100vw, 900px"
                                class="absolute inset-0 w-full h-full object-cover"
                            />
                        </div>
                    ) : null
                }

                <!-- Тело из MD (передаётся через slot) -->
                <div
                    class="modal-body mt-16 text-slate-700 text-base md:text-lg leading-relaxed"
                >
                    <slot />
                </div>
            </article>
        </div>
    </div>
</dialog>

<style>
    /* Отключаем синюю рамку при фокусе */
    dialog:focus-visible {
        outline: none;
    }

    /* Анимации при открытии */
    dialog[open] .modal-content {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    /* Кастомный скроллбар для внутреннего контента */
    .custom-scroll::-webkit-scrollbar {
        width: 8px;
    }
    .custom-scroll::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scroll::-webkit-scrollbar-thumb {
        background-color: #cbd5e1; /* slate-300 */
        border-radius: 20px;
        border: 2px solid #ffffff;
    }
    .custom-scroll::-webkit-scrollbar-thumb:hover {
        background-color: #94a3b8; /* slate-400 */
    }

    /* Markdown body styling */
    .modal-body :global(p) {
        margin-bottom: 1.25rem;
    }
    .modal-body :global(ul),
    .modal-body :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
    }
    .modal-body :global(ul) {
        list-style-type: disc;
    }
    .modal-body :global(ol) {
        list-style-type: decimal;
    }
    .modal-body :global(li) {
        margin-bottom: 0.4rem;
    }
    .modal-body :global(strong) {
        font-weight: 700;
        color: #1e293b;
    }
    .modal-body :global(h2),
    .modal-body :global(h3),
    .modal-body :global(h4) {
        font-family: var(--font-heading);
        text-transform: uppercase;
        color: #0f172a;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
    }

    /* Responsive VK video wrapper embedded in markdown */
    .modal-body :global(.video-embed) {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        margin-bottom: 1.5rem;
        border-radius: 0.25rem;
        overflow: hidden;
        background: #000;
    }
    .modal-body :global(.video-embed iframe) {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: none;
    }
</style>
