---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import EquipmentCard from "../equipment/EquipmentCard.astro";

const equipmentCollection = await getCollection("equipment");
const fleet = equipmentCollection
  .flatMap((entry) => entry.data.items)
  .filter((item) => item.featured)
  .sort((a, b) => a.featuredOrder - b.featuredOrder)
  .slice(0, 6);

// Бегущая строка — повторяем 3 раза для бесшовного loop
const marqueeItems = [
  "Самосвалы",
  "Экскаваторы",
  "Бульдозеры",
  "Катки",
  "Асфальтоукладчики",
  "Установки ГНБ",
  "Краны и КМУ",
  "Водовозки",
];
---

<section
  class="fleet-section relative overflow-hidden py-16 md:py-24"
  aria-labelledby="fleet-heading"
>
  <!-- Фоновая сетка -->
  <div
    class="fleet-bg-grid absolute inset-0 pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10">
    <!-- Заголовок -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div
        class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6"
      >
        <div>
          <!-- <div class="flex items-center gap-3 mb-4 justify-left">
                <div
                    class="w-2 h-2 bg-brand-dark rounded-full"
                    aria-hidden="true"
                >
                </div>
                <span
                    class="text-sm font-bold tracking-widest uppercase text-brand-dark"
                    >Заказ спецтехники</span
                >
            </div> -->
          <h2
            id="fleet-heading"
            class="font-heading text-white uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide"
          >
            Наш автопарк
          </h2>
        </div>
        <p class="text-slate-400 text-base lg:text-lg max-w-md leading-relaxed">
          Подача на объект — в день обращения.
        </p>
      </div>
    </div>

    <!-- Бегущая строка (CSS marquee) -->
    <div class="overflow-hidden mb-12 border-y border-white/10 py-4" aria-hidden="true">
      <div class="fleet-marquee-track">
        {
          [...marqueeItems, ...marqueeItems].map((item) => (
            <span class="fleet-marquee-item flex items-center gap-6 px-8 text-slate-400 text-sm font-semibold tracking-widest uppercase whitespace-nowrap">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-light flex-shrink-0" aria-hidden="true" />
              {item}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Swiper слайдер карточек -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="swiper swiper-fleet" id="swiper-fleet">
        <div class="swiper-wrapper">
          {
            fleet.map((item) => (
              <div class="swiper-slide !h-auto">
                <EquipmentCard
                  title={item.title}
                  specs={item.specs}
                  category={item.category}
                  image={item.image}
                  actionType="link"
                  href="/arenda-spetstehniki"
                  buttonLabel="Арендовать"
                />
              </div>
            ))
          }
        </div>

        <!-- Navigation -->
        <div
          class="swiper-fleet-prev swiper-nav-btn"
          aria-label="Предыдущий слайд"
        >
          <Icon name="lucide:chevron-left" class="w-5 h-5" />
        </div>
        <div
          class="swiper-fleet-next swiper-nav-btn"
          aria-label="Следующий слайд"
        >
          <Icon name="lucide:chevron-right" class="w-5 h-5" />
        </div>

        <!-- Pagination -->
        <div class="swiper-fleet-pagination mt-8 flex justify-center gap-2">
        </div>
      </div>

      <!-- CTA под слайдером -->
      <div class="text-center mt-10">
        <a
          href="/arenda-spetstehniki"
          class="inline-flex items-center gap-2 px-8 py-4 rounded font
                  uppercase tracking-wide text-white border border-white/20
                  hover:bg-white/10 transition-all duration-300 text-sm"
        >
          Смотреть весь автопарк
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .fleet-section {
    background-color: #080e1c;
  }
  .fleet-bg-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* CSS Marquee Animation */
  .fleet-marquee-track {
    display: flex;
    width: fit-content;
    animation: fleet-marquee 30s linear infinite;
  }

  .fleet-marquee-item {
    flex-shrink: 0;
  }

  @keyframes fleet-marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Навигационные кнопки слайдера */
  .swiper-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition:
      background 0.25s,
      border-color 0.25s;
  }
  .swiper-nav-btn:hover {
    background: rgba(41, 127, 236, 0.3);
    border-color: rgba(41, 127, 236, 0.5);
  }
  .swiper-nav-btn.swiper-button-disabled {
    opacity: 0.3;
    pointer-events: none;
  }
  .swiper-fleet-prev {
    left: -1.5rem;
  }
  .swiper-fleet-next {
    right: -1.5rem;
  }

  /* Пагинация */
  :global(.swiper-fleet-pagination .swiper-pagination-bullet) {
    width: 6px;
    height: 6px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    display: inline-block;
    transition:
      background 0.3s,
      width 0.3s;
    cursor: pointer;
  }
  :global(.swiper-fleet-pagination .swiper-pagination-bullet-active) {
    background: #297fec;
    width: 20px;
    border-radius: 3px;
  }

  /* Карточка — равная высота слайдов */
  #swiper-fleet {
    overflow: visible;
    padding: 0 2rem;
  }
  @media (max-width: 768px) {
    #swiper-fleet {
      padding: 0;
    }
    .swiper-fleet-prev,
    .swiper-fleet-next {
      display: none;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, A11y } from "swiper/modules";
  import "swiper/css";

  // ── Карусель карточек ──
  new Swiper("#swiper-fleet", {
    modules: [Navigation, Pagination, A11y],
    slidesPerView: 1,
    spaceBetween: 20,
    grabCursor: true,
    navigation: {
      prevEl: ".swiper-fleet-prev",
      nextEl: ".swiper-fleet-next",
    },
    pagination: {
      el: ".swiper-fleet-pagination",
      clickable: true,
    },
    breakpoints: {
      640: { slidesPerView: 2, spaceBetween: 20 },
      1024: { slidesPerView: 3, spaceBetween: 24 },
    },
    a11y: { enabled: true },
  });
</script>
