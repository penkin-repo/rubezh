---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import cogs from "../../assets/cogs.svg";
import ServiceModal from "./ServiceModal.astro";

const servicesRaw = await getCollection("services");
const services = await Promise.all(
    servicesRaw
        .sort((a, b) => a.data.order - b.data.order)
        .map(async (entry) => {
            const { Content } = await render(entry);
            return { data: entry.data, id: entry.id, Content };
        })
);
---

<section class="services-section relative bg-white text-slate-900 z-10">
    <!-- Зубчатый переход сверху — cogs.svg repeat-x -->
    <div
        class="services-teeth"
        style={`background-image: url(${cogs.src})`}
        aria-hidden="true"
    >
    </div>

    

    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-32">
        <!-- Заголовок секции -->
        <div class="text-center mb-14">
            <!-- <div class="flex items-center gap-3 mb-4 justify-center">
                <div
                    class="w-2 h-2 bg-brand-dark rounded-full"
                    aria-hidden="true"
                >
                </div>
                <span
                    class="text-sm font-bold tracking-widest uppercase text-brand-dark"
                    >Услуги</span
                >
            </div> -->
            <h2
                class="font-heading text-slate-900 uppercase text-3xl sm:text-4xl lg:text-5xl leading-none tracking-wide"
            >
                Основные виды<br />деятельности
            </h2>
            <p class="text-lg text-slate-600 mt-4">
                Полный цикл работ от проектирования до сдачи объекта в
                эксплуатацию
            </p>
        </div>

        <!-- Bento Box сетка -->
        <div class="bento-grid">
            {
                services.map(({ data, id }) => (
                    <button
                        class={`service-card group text-left w-full js-open-modal${data.size === 'large' ? ' bento-large' : ''}`}
                        data-target={`modal-${id}`}
                    >
                        <Image
                            src={data.image}
                            alt={data.title}
                            widths={data.size === 'large' ? [640, 900, 1200] : [400, 600]}
                            sizes={data.size === 'large' ? '(max-width: 768px) 100vw, 60vw' : '(max-width: 768px) 100vw, 30vw'}
                            loading="lazy"
                            quality={85}
                            class="service-card__img"
                        />
                        <div class="service-card__overlay"></div>
                        <div class="service-card__content">
                            <h3 class="service-card__title">{data.title}</h3>
                            <p class="service-card__desc">{data.desc}</p>
                            <span class="service-card__link">Подробнее →</span>
                        </div>
                    </button>
                ))
            }
        </div>
    </div>
</section>

<!-- Рендеринг всех модальных окон -->
{
    services.map(({ data, id, Content }) => (
        <ServiceModal
            id={id}
            title={data.title}
            desc={data.desc}
            image={data.hideModalImage ? undefined : data.image}
            videoEmbedUrl={data.videoEmbedUrl}
        >
            <Content />
        </ServiceModal>
    ))
}

<style>
    .services-section {
        background-image:
            linear-gradient(#00000010 1px, #0000 1px),
            linear-gradient(90deg, #00000010 1px, #0000 1px);
        background-size: 60px 60px;
        background-color: #f7f8fa;
    }

    /* ====================================================
     Зубчатый переход — повторяющийся SVG-тайл cogs.svg
     ==================================================== */
    .services-teeth {
        --tooth-w: 230px;
        --tooth-h: 88px;
        width: 100%;
        height: var(--tooth-h);
        background-color: transparent;
        background-repeat: repeat-x;
        background-position: top left;
        background-size: var(--tooth-w) var(--tooth-h);
        position: absolute;
        top: 30px;
        left: 0;
        right: 0;
        transform: translateY(-100%);
        z-index: 20;
        pointer-events: none;
    }

    /* ====================================================
     Bento Box сетка
     ==================================================== */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: auto auto;
        gap: 1rem;
    }

    @media (max-width: 768px) {
        .bento-grid {
            grid-template-columns: 1fr;
        }
        .bento-large {
            grid-column: span 1 !important;
        }
    }

    .bento-large {
        grid-column: span 2;
        min-height: 420px;
    }

    /* ====================================================
     Карточка услуги
     ==================================================== */
    .service-card {
        position: relative;
        overflow: hidden;
        border-radius: 0.25rem;
        min-height: 400px;
        cursor: pointer;
        border: none;
        outline: none;
        display: block;
    }

    /* Фоновое изображение */
    .service-card__img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Zoom при наведении */
    .service-card:hover .service-card__img,
    .service-card:focus-visible .service-card__img {
        transform: scale(1.07);
    }

    /* Градиентный оверлей */
    .service-card__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(2, 10, 30, 0.92) 0%,
            rgba(2, 10, 30, 0.45) 50%,
            rgba(2, 10, 30, 0.1) 100%
        );
        transition: background 0.35s ease;
    }

    /* При наведении усиливаем оверлей брендовым цветом */
    .service-card:hover .service-card__overlay,
    .service-card:focus-visible .service-card__overlay {
        background: linear-gradient(
            to top,
            rgba(2, 87, 192, 0.92) 0%,
            rgba(2, 87, 192, 0.5) 55%,
            rgba(2, 87, 192, 0.12) 100%
        );
    }

    /* Контент внутри карточки */
    .service-card__content {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.75rem;
    }

    .service-card__title {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        line-height: 1.1;
        text-transform: uppercase;
        color: #ffffff;
        margin: 0 0 0.5rem;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    }

    .bento-large .service-card__title {
        /* font-size: 2.5rem; */
    }

    /* Описание — скрыто по умолчанию, выезжает при hover */
    .service-card__desc {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.55;
        margin: 0 0 0.875rem;
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transform: translateY(10px);
        transition:
            max-height 0.8s ease,
            opacity 0.35s ease 0.05s,
            transform 0.35s ease 0.05s;
    }

    .service-card:hover .service-card__desc,
    .service-card:focus-visible .service-card__desc {
        max-height: 8rem;
        opacity: 1;
        transform: translateY(0);
    }

    /* Ссылка «Подробнее» */
    .service-card__link {
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #ffffff;
        text-decoration: none;
        opacity: 0;
        transform: translateY(8px);
        transition:
            opacity 0.3s ease 0.1s,
            transform 0.3s ease 0.1s;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .service-card:hover .service-card__link,
    .service-card:focus-visible .service-card__link {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const openButtons =
            document.querySelectorAll<HTMLButtonElement>(".js-open-modal");
        const closeButtons =
            document.querySelectorAll<HTMLButtonElement>(".js-close-modal");

        // Открытие модалки
        openButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const targetId = btn.dataset.target;
                if (!targetId) return;

                const dialog = document.getElementById(
                    targetId,
                ) as HTMLDialogElement;
                if (dialog) {
                    dialog.showModal();
                    document.body.style.overflow = "hidden"; // block scrolling behind modal
                }
            });
        });

        // Закрытие модалки по кнопке "Х"
        closeButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const targetId = btn.dataset.modal;
                if (!targetId) return;

                const dialog = document.getElementById(
                    `modal-${targetId}`,
                ) as HTMLDialogElement;
                if (dialog) {
                    dialog.close();
                    document.body.style.overflow = "";
                }
            });
        });

        // Закрытие по клику на backdrop
        document.querySelectorAll("dialog").forEach((dialog) => {
            dialog.addEventListener("click", (e) => {
                const rect = dialog.getBoundingClientRect();
                const isInDialog =
                    rect.top <= e.clientY &&
                    e.clientY <= rect.top + rect.height &&
                    rect.left <= e.clientX &&
                    e.clientX <= rect.left + rect.width;
                if (!isInDialog) {
                    dialog.close();
                    document.body.style.overflow = "";
                }
            });
        });

        // Закрытие по Escape (нативный диалог сам закрывается, нужно только вернуть скролл)
        document.querySelectorAll("dialog").forEach((dialog) => {
            dialog.addEventListener("close", () => {
                document.body.style.overflow = "";
            });
        });
    });
</script>
