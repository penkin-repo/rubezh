---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { getProjectImages } from '../../utils/project-images';

const allWorkImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/works/**/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

const allProjects = await getCollection('projects2');
const sorted = allProjects.sort((a, b) => {
  if (a.data.year !== b.data.year) return b.data.year - a.data.year;
  return a.data.order - b.data.order;
});

const years = [...new Set(sorted.map((p) => p.data.year))].sort((a, b) => b - a);

const HOME_LIMIT = 2;
const projectsByYear: Record<number, typeof sorted> = {};
for (const year of years) {
  projectsByYear[year] = sorted.filter((p) => p.data.year === year).slice(0, HOME_LIMIT);
}

const imageCache = new Map<string, ImageMetadata[]>();
for (const p of sorted) {
  imageCache.set(p.data.imageFolder, getProjectImages(allWorkImages, p.data.imageFolder));
}
---

<section class="py-16 md:py-24 bg-zinc-50" aria-labelledby="projects3-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Заголовок -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-10">
      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-brand-dark mb-2">Проекты 3</p>
        <h2 id="projects3-heading"
            class="font-heading text-zinc-900 uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide">
          Проекты
        </h2>
      </div>
      <a href="/proekty2"
         class="inline-flex items-center gap-2 text-sm font-semibold text-brand-dark
                hover:text-brand-light transition-colors duration-200 self-end">
        Все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <!-- Экран 1: Карточки годов -->
    <div id="p3-years-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {years.map((year) => {
        const firstProject = projectsByYear[year][0];
        const count = projectsByYear[year].length;
        const yearCoverImages = imageCache.get(firstProject.data.imageFolder) || [];
        const hasCover = yearCoverImages.length > 0;
        return (
          <button
            class="p3-year-card group relative rounded-xl overflow-hidden cursor-pointer
                   shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1
                   aspect-[4/3] sm:aspect-[3/2] border border-zinc-200"
            data-year={year}
          >
            {hasCover ? (
              <Image
                src={yearCoverImages[0]}
                alt={`Проекты ${year} года`}
                widths={[400, 600]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                loading="lazy"
                quality={75}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-brand-dark to-brand-light"></div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-6">
              <span class="font-heading text-white text-4xl sm:text-5xl lg:text-6xl uppercase leading-none">
                {year}
              </span>
              <p class="text-white/80 text-sm mt-2">
                {count} {count === 1 ? 'объект' : count < 5 ? 'объекта' : 'объектов'}
              </p>
            </div>
            <div class="absolute top-4 right-4 bg-white/90 rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-sm">
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-zinc-900" />
            </div>
          </button>
        );
      })}
    </div>

    <!-- Экран 2: Проекты года (скрыт изначально) -->
    <div id="p3-projects-view" class="hidden">
      <!-- Кнопка «Назад» -->
      <button
        id="p3-back-btn"
        class="inline-flex items-center gap-2 text-sm font-semibold text-brand-dark hover:text-brand-light
               transition-colors duration-200 mb-8 cursor-pointer"
      >
        <Icon name="lucide:arrow-left" class="w-4 h-4" />
        Назад к выбору годов
      </button>

      <!-- Контейнер проектов по годам -->
      {years.map((year) => (
        <div class="p3-year-projects hidden space-y-8" data-year-projects={year}>
          <h3 class="font-heading text-zinc-900 uppercase text-2xl sm:text-3xl leading-none mb-6">
            Проекты {year} г.
          </h3>

          {projectsByYear[year].map((project) => {
            const images = imageCache.get(project.data.imageFolder) || [];
            const hasImages = images.length > 0;
            return (
            <article
              class="project3-gallery bg-white rounded overflow-hidden shadow-sm border border-zinc-100 hover:shadow-md transition-shadow duration-300"
            >
              <div class="flex flex-col md:flex-row">
                {hasImages ? (
                <a
                  href={images[0].src}
                  data-pswp-width={images[0].width}
                  data-pswp-height={images[0].height}
                  target="_blank"
                  class="project3-cover md:w-2/5 lg:w-[45%] flex-shrink-0 relative group cursor-zoom-in block"
                  aria-label={`Открыть галерею: ${project.data.title}`}
                >
                  <div class="aspect-[4/3] overflow-hidden">
                    <Image
                      src={images[0]}
                      alt={project.data.title}
                      widths={[400, 600]}
                      sizes="(max-width: 768px) 100vw, 45vw"
                      loading="lazy"
                      quality={75}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                  <div class="absolute right-3 top-3 rounded bg-white/90 px-2.5 py-1 text-xs font-semibold text-zinc-900
                              opacity-0 transition-all duration-300 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0
                              flex items-center gap-1.5 shadow-sm">
                    <Icon name="lucide:images" class="w-3.5 h-3.5" />
                    {images.length} фото
                  </div>
                  <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                    <span class="bg-white/90 rounded px-3 py-1.5 text-xs font-semibold text-zinc-900 shadow-sm">
                      Открыть галерею
                    </span>
                  </div>
                </a>
                ) : (
                <div class="md:w-2/5 lg:w-[45%] flex-shrink-0">
                  <div class="aspect-[4/3] bg-zinc-100 flex flex-col items-center justify-center text-zinc-400">
                    <Icon name="lucide:image-off" class="w-10 h-10 mb-2" />
                    <span class="text-xs font-medium">Фото скоро</span>
                  </div>
                </div>
                )}

                <!-- Текст справа -->
                <div class="flex-1 p-5 md:p-6 lg:p-8 flex flex-col justify-center">
                  <h4 class="font-heading text-zinc-900 uppercase text-xl sm:text-2xl leading-tight mb-4">
                    {project.data.title}
                  </h4>

                  <div class="space-y-3 text-sm">
                    <div class="flex gap-3">
                      <div class="flex-shrink-0 w-5 h-5 mt-0.5 text-brand-dark">
                        <Icon name="lucide:hard-hat" class="w-5 h-5" />
                      </div>
                      <div>
                        <span class="font-semibold text-zinc-500 uppercase text-xs tracking-wide">Виды работ</span>
                        <p class="text-zinc-700 mt-0.5 leading-relaxed">{project.data.works}</p>
                      </div>
                    </div>

                    <div class="flex gap-3">
                      <div class="flex-shrink-0 w-5 h-5 mt-0.5 text-brand-dark">
                        <Icon name="lucide:building-2" class="w-5 h-5" />
                      </div>
                      <div>
                        <span class="font-semibold text-zinc-500 uppercase text-xs tracking-wide">Заказчик</span>
                        <p class="text-zinc-900 font-medium mt-0.5">{project.data.client}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Скрытые фото для галереи -->
              {images.slice(1).map((img) => (
                <a
                  href={img.src}
                  data-pswp-width={img.width}
                  data-pswp-height={img.height}
                  target="_blank"
                  class="hidden"
                >
                  <Image
                    src={img}
                    alt={`${project.data.title} фото`}
                    width={img.width > 1200 ? 1200 : img.width}
                    loading="lazy"
                    quality={75}
                  />
                </a>
              ))}
            </article>
            );
          })}
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/proekty2"
         class="inline-flex items-center gap-2 px-8 py-4 rounded uppercase tracking-wide
                text-white bg-brand-dark hover:bg-brand-light transition-colors duration-300 text-sm">
        Смотреть все проекты
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

<style>
  @import '../../styles/photoswipe-custom.css';
</style>

<script>
  import { initPhotoSwipe } from '../../scripts/photoswipe-init';

  const yearsGrid = document.getElementById('p3-years-grid')!;
  const projectsView = document.getElementById('p3-projects-view')!;
  const backBtn = document.getElementById('p3-back-btn')!;
  const yearCards = document.querySelectorAll<HTMLButtonElement>('.p3-year-card');
  const yearProjects = document.querySelectorAll<HTMLElement>('.p3-year-projects');

  // Клик по карточке года → показать проекты
  yearCards.forEach(card => {
    card.addEventListener('click', () => {
      const year = card.dataset.year;

      // Скрыть сетку годов
      yearsGrid.classList.add('hidden');

      // Показать проекты
      projectsView.classList.remove('hidden');

      // Показать нужный год
      yearProjects.forEach(el => {
        if (el.dataset.yearProjects === year) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });

    });
  });

  // Кнопка «Назад»
  backBtn.addEventListener('click', () => {
    projectsView.classList.add('hidden');
    yearsGrid.classList.remove('hidden');

  });

  // PhotoSwipe для всех галерей
  initPhotoSwipe({
    gallery: '.project3-gallery',
    children: 'a',
  });
</script>
