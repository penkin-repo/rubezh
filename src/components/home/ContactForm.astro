---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
// Данные: Шаг 4.1 → п.5 CTA блок, PROJECT_LOG_HOW → данные компании

const [contactsEntry] = (await getCollection("site")).sort((a, b) =>
    a.id.localeCompare(b.id),
);

if (!contactsEntry) {
    throw new Error("Site contacts content is missing in src/content/site.");
}

const contacts = contactsEntry.data;
---

<section
    class="contact-form-section relative overflow-hidden py-16 md:py-24"
    aria-labelledby="cta-heading"
>
    <!-- Фоновый паттерн -->
    <div
        class="cta-bg-pattern absolute inset-0 pointer-events-none"
        aria-hidden="true"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <!-- Левая колонка: текст -->
            <div>
                <!-- <div class="flex items-center gap-3 mb-6">
                    <span class="w-10 h-0.5 bg-white/50" aria-hidden="true"
                    ></span>
                    <span
                        class="text-white/70 text-xs font-semibold tracking-widest uppercase"
                        >Обсудим ваш проект</span
                    >
                </div> -->
                <h2
                    id="cta-heading"
                    class="font-heading text-white uppercase text-4xl sm:text-5xl lg:text-6xl leading-none tracking-wide mb-6"
                >
                    Свяжитесь с нами
                </h2>
                <p
                    class="text-white/75 text-base lg:text-lg leading-relaxed mb-10"
                >
                    Оставьте заявку и мы подберём оптимальную технику и
                    предложим лучшие условия для вашего объекта.
                </p>

                <!-- Быстрые контакты -->
                <div class="space-y-3">
                    <!--
                    <a
                        href={`tel:${contacts.mainPhoneHref}`}
                        class="flex items-center gap-3 text-white hover:text-white/80 transition-colors group"
                    >
                        <span
                            class="w-10 h-10 rounded bg-white/10 border border-white/20 flex items-center justify-center
                         group-hover:bg-white/20 transition-colors flex-shrink-0"
                        >
                            <Icon name="lucide:phone" class="w-4 h-4" />
                        </span>
                        <span class="font-semibold">{contacts.mainPhoneDisplay}</span>
                    </a>
                    -->
                    <a
                        href={`mailto:${contacts.officeEmail}`}
                        class="flex items-center gap-3 text-white hover:text-white/80 transition-colors group"
                    >
                        <span
                            class="w-10 h-10 rounded bg-white/10 border border-white/20 flex items-center justify-center
                         group-hover:bg-white/20 transition-colors flex-shrink-0"
                        >
                            <Icon name="lucide:mail" class="w-4 h-4" />
                        </span>
                        <span>{contacts.officeEmail}</span>
                    </a>
                </div>
            </div>

            <!-- Правая колонка: форма -->
            <div class="relative">
                <!-- Скрытый iframe и форма для отправки в Google Apps Script -->
                <iframe
                    name="cf-gas-iframe"
                    id="cf-gas-iframe"
                    class="hidden"
                    tabindex="-1"
                    aria-hidden="true"
                ></iframe>
                <form
                    id="cf-gas-hidden-form"
                    method="POST"
                    target="cf-gas-iframe"
                    class="hidden"
                    tabindex="-1"
                >
                    <input type="hidden" name="fio" />
                    <input type="hidden" name="phone" />
                    <input type="hidden" name="comment" />
                    <input type="hidden" name="source" />
                    <input type="hidden" name="consent" />
                </form>

                <!-- Форма -->
                <form
                    id="contact-form"
                    data-main-phone={contacts.mainPhoneDisplay}
                    class="cta-form relative bg-white rounded p-8 shadow-2xl min-h-[430px]"
                    novalidate
                >
                    <!-- <h3
                        class="font-heading text-zinc-900 uppercase text-2xl mb-6"
                    >
                        Получить расчёт
                    </h3> -->

                    <!-- Имя -->
                    <div class="mb-5">
                        <label
                            for="cf-name"
                            class="block text-sm font-semibold text-zinc-700 mb-2"
                            >Ваше имя *</label
                        >
                        <input
                            type="text"
                            id="cf-name"
                            name="name"
                            required
                            placeholder="Иван Петров"
                            class="w-full px-4 py-3 rounded border border-zinc-200 text-zinc-900
                     focus:outline-none focus:ring-2 focus:ring-brand-dark focus:border-transparent
                     transition-all duration-200 text-sm"
                        />
                    </div>

                    <!-- Телефон -->
                    <div class="mb-5">
                        <label
                            for="cf-phone"
                            class="block text-sm font-semibold text-zinc-700 mb-2"
                            >Номер телефона *</label
                        >
                        <input
                            type="tel"
                            id="cf-phone"
                            name="phone"
                            required
                            placeholder="8 (___) ___-__-__"
                            maxlength="17"
                            class="w-full px-4 py-3 rounded border border-zinc-200 text-zinc-900
                     focus:outline-none focus:ring-2 focus:ring-brand-dark focus:border-transparent
                     transition-all duration-200 text-sm"
                        />
                    </div>

                    <!-- Комментарий -->
                    <div class="mb-6">
                        <label
                            for="cf-comment"
                            class="block text-sm font-semibold text-zinc-700 mb-2"
                            >Комментарий</label
                        >
                        <textarea
                            id="cf-comment"
                            name="comment"
                            rows="3"
                            placeholder="Опишите задачу: тип работ, адрес объекта, сроки..."
                            class="w-full px-4 py-3 rounded border border-zinc-200 text-zinc-900
                     focus:outline-none focus:ring-2 focus:ring-brand-dark focus:border-transparent
                     transition-all duration-200 text-sm resize-none"
                        ></textarea>
                    </div>

                    <!-- Submit -->
                    <button
                        type="submit"
                        id="cf-submit"
                        class="cta-submit-btn w-full py-4 px-8 rounded uppercase tracking-wide
                   text-white text-sm transition-all duration-300"
                    >
                        <span id="cf-btn-text">Отправить заявку</span>
                        <span id="cf-spinner" class="hidden">
                            <Icon
                                name="lucide:loader-circle"
                                class="w-5 h-5 animate-spin inline"
                            />
                            Отправляем...
                        </span>
                    </button>

                    <p
                        id="cf-error"
                        class="hidden mt-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2"
                        role="alert"
                    ></p>

                    <label class="mt-4 flex items-start gap-2.5 text-xs text-zinc-500">
                        <input
                            type="checkbox"
                            id="cf-consent"
                            name="consent"
                            class="mt-0.5 h-4 w-4 rounded border-zinc-300 text-brand-dark focus:ring-brand-dark"
                        />
                        <span>
                            Я соглашаюсь с
                            <a
                                href="/privacy"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-brand-dark underline hover:no-underline"
                            >
                                политикой конфиденциальности
                            </a>
                            и обработкой персональных данных.
                        </span>
                    </label>
                </form>

                <!-- Успех -->
                <div
                    id="form-success"
                    class="hidden bg-white rounded p-8 shadow-2xl min-h-[430px]
                 flex flex-col items-center justify-center text-center"
                >
                    <div
                        class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mb-5"
                    >
                        <Icon
                            name="lucide:check"
                            class="w-8 h-8 text-green-600"
                        />
                    </div>
                    <h3
                        class="font-heading text-zinc-900 uppercase text-2xl mb-3"
                    >
                        Заявка принята!
                    </h3>
                    <p class="text-zinc-500 text-base leading-relaxed">
                        Наш инженер свяжется с вами в ближайшее время для
                        расчёта стоимости.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-form-section {
        background: linear-gradient(
            135deg,
            #0257c0 0%,
            #0c1a3a 60%,
            #060b18 100%
        );
    }
    .cta-bg-pattern {
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }
    .cta-submit-btn {
        background: linear-gradient(135deg, #0257c0, #297fec);
        box-shadow: 0 4px 16px rgba(2, 87, 192, 0.4);
    }
    .cta-submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 24px rgba(2, 87, 192, 0.55);
    }
    .cta-submit-btn:disabled {
        opacity: 0.7;
        transform: none;
        cursor: not-allowed;
    }
</style>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const phoneInput = document.getElementById("cf-phone") as HTMLInputElement;
    const submitBtn = document.getElementById("cf-submit") as HTMLButtonElement;
    const btnText = document.getElementById("cf-btn-text") as HTMLElement;
    const spinner = document.getElementById("cf-spinner") as HTMLElement;
    const success = document.getElementById("form-success") as HTMLElement;
    const errorBox = document.getElementById("cf-error") as HTMLElement;
    const consentInput = document.getElementById("cf-consent") as HTMLInputElement;
    const hiddenForm = document.getElementById(
        "cf-gas-hidden-form",
    ) as HTMLFormElement;
    const fallbackMainPhone = form?.dataset.mainPhone ?? "";

    let successResetTimer: number | undefined;

    const showError = (message: string) => {
        if (!errorBox) return;
        errorBox.textContent = message;
        errorBox.classList.remove("hidden");
    };

    const hideError = () => {
        if (!errorBox) return;
        errorBox.textContent = "";
        errorBox.classList.add("hidden");
    };

    const setLoading = (isLoading: boolean) => {
        if (!(submitBtn instanceof HTMLButtonElement)) return;
        submitBtn.disabled = isLoading;
        btnText?.classList.toggle("hidden", isLoading);
        spinner?.classList.toggle("hidden", !isLoading);
    };

    const resetFormState = () => {
        if (!(form instanceof HTMLFormElement)) return;
        form.reset();
        form.classList.remove("hidden");
        success?.classList.add("hidden");
        setLoading(false);
        hideError();
    };

    // ── Маска телефона 8 (___) ___-__-__ ──
    phoneInput?.addEventListener("input", () => {
        let raw = phoneInput.value.replace(/\D/g, "");
        if (raw.startsWith("7")) raw = "8" + raw.slice(1);
        if (!raw.startsWith("8") && raw.length > 0) raw = "8" + raw;
        raw = raw.slice(0, 11);

        let formatted = "8";
        if (raw.length > 1) formatted += " (" + raw.slice(1, 4);
        if (raw.length >= 4) formatted += ") " + raw.slice(4, 7);
        if (raw.length >= 7) formatted += "-" + raw.slice(7, 9);
        if (raw.length >= 9) formatted += "-" + raw.slice(9, 11);

        phoneInput.value = formatted;
    });

    // ── Отправка формы → Google Apps Script (через iframe, без CORS) ──
    // ВАЖНО: Замените URL ниже на ваш задеплоенный Google Apps Script Web App URL
    const APPS_SCRIPT_URL =
        "https://script.google.com/macros/s/AKfycbzMqNnWkWI9RpuMJWVlGdG7Fzdcay5BGH4Zg1iqsOwpi-OR5DsGXLh9UARmMYzlfKcseg/exec";
    if (hiddenForm) hiddenForm.action = APPS_SCRIPT_URL;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        hideError();

        const name = (
            document.getElementById("cf-name") as HTMLInputElement
        ).value.trim();
        const phone = (
            document.getElementById("cf-phone") as HTMLInputElement
        ).value.trim();
        const comment = (
            document.getElementById("cf-comment") as HTMLTextAreaElement
        ).value.trim();

        if (!name || !phone) {
            showError("Заполните обязательные поля: имя и телефон.");
            return;
        }

        if (phone.replace(/\D/g, "").length < 11) {
            showError("Введите телефон полностью в формате 8 (___) ___-__-__.");
            return;
        }

        if (!(consentInput instanceof HTMLInputElement) || !consentInput.checked) {
            showError("Подтвердите согласие с политикой конфиденциальности.");
            return;
        }

        setLoading(true);

        try {
            if (!(hiddenForm instanceof HTMLFormElement)) {
                throw new Error("Hidden form not found");
            }

            (hiddenForm.querySelector('input[name="fio"]') as HTMLInputElement).value =
                name;
            (hiddenForm.querySelector('input[name="phone"]') as HTMLInputElement).value =
                phone;
            (hiddenForm.querySelector('input[name="comment"]') as HTMLInputElement).value =
                comment;
            (hiddenForm.querySelector('input[name="source"]') as HTMLInputElement).value =
                "Главная страница";
            (hiddenForm.querySelector('input[name="consent"]') as HTMLInputElement).value =
                "Да";
            hiddenForm.submit();

            form.classList.add("hidden");
            success.classList.remove("hidden");

            if (successResetTimer) window.clearTimeout(successResetTimer);
            successResetTimer = window.setTimeout(() => {
                resetFormState();
            }, 2200);
        } catch {
            setLoading(false);
            showError(
                `Не удалось отправить заявку. Попробуйте ещё раз или позвоните: ${fallbackMainPhone}.`,
            );
        }
    });
</script>
