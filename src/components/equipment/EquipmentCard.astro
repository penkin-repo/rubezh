---
// src/components/equipment/EquipmentCard.astro
import { Image } from 'astro:assets';

interface Props {
    title: string;
    specs: string;
    image: ImageMetadata;
    category: string;
    actionType?: 'modal' | 'link';
    href?: string;
    buttonLabel?: string;
}

const {
    title,
    specs,
    image,
    category,
    actionType = 'modal',
    href = '/arenda-spetstehniki',
    buttonLabel = 'Оставить заявку',
} = Astro.props;
---

<div
    class="equipment-card group h-full bg-white rounded border border-zinc-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col"
    data-category={category}
>
    <div class="aspect-[4/3] overflow-hidden bg-white border-b-1 border-zinc-200">
        <Image
            src={image}
            alt={title}
            widths={[400, 600]}
            sizes="(max-width: 640px) 400px, 600px"
            loading="lazy"
            quality={75}
            class="object-contain w-full h-full p-2"
        />
    </div>
    <div class="p-5 flex flex-col flex-1">
        <div class="mb-2">
            <span class="inline-block px-3 py-1 text-xs font-semibold text-brand-dark bg-brand-light/10 rounded">
                {category}
            </span>
        </div>
        <h3 class="text-xl font-bold text-zinc-900 mb-2">{title}</h3>
        <p class="text-zinc-600 text-sm">{specs}</p>
    </div>

    {
        actionType === 'modal' ? (
            <button
                class="mt-auto w-full text-center px-5 py-3 border-t border-zinc-200 bg-white text-zinc-800 bg-zinc-50 hover:bg-zinc-100 transition-colors font-semibold rounded-none cursor-pointer"
                onclick="openRentalForm(this)"
                data-equipment={title}
            >
                {buttonLabel}
            </button>
        ) : (
            <a
                href={href}
                class="mt-auto px-5 py-3 border-t border-zinc-200 bg-white text-zinc-800 hover:bg-zinc-50 transition-colors font-semibold text-left rounded-none cursor-pointer block"
            >
                {buttonLabel}
            </a>
        )
    }
</div>
